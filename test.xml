				<_attribute>Age (Years)</_attribute>
				<size>4</size>
			</column>
			<column>
				<_attribute>Age (Months)</_attribute>
				<size>4</size>
			</column>
			<column>
				<_attribute>Sex</_attribute>
				<size>3</size>
				<_longname>If Male write "M." If Female write "F."</_longname>
			</column>
			<column>
				<_attribute>Marriage/Orphanhood</_attribute>
				<size>10</size>
				<_longname>Age 15+: "Single," "Married," "Widower," or "Widow." Under 15: "Both parents alive," "Father is dead," "Mother is dead," or "Both parents dead."</_longname>
			</column>
			<column>
				<_attribute>Birthplace</_attribute>
				<size>15</size>
				<_longname>If born in Ireland, write name of County and of Townland or Town. If born outside Ireland, write name of Country and of County, State, Province or District. If born at sea, write "At sea."</_longname>
			</column>
			<column>
				<_attribute>Irish Language</_attribute>
				<size>12</size>
				<_longname>"Irish only" (speaks only Irish); "Irish and English" (native Irish speaker who can also speak English); "English and Irish" (speaks both but not a native Irish speaker); "Read but cannot speak Irish." Leave blank for persons who can neither speak nor read Irish.</_longname>
			</column>
			<column>
				<_attribute>Religion</_attribute>
				<size>10</size>
				<_longname>Religion or Religious Denomination. Members of Protestant Denominations should state name of particular Church, Denomination or body.</_longname>
			</column>
			<column>
				<_attribute>Personal Occupation</_attribute>
				<size>18</size>
			</column>
			<column>
				<_attribute>Employment</_attribute>
				<size>18</size>
				<_longname>(1) If working for an Employer, state name and business of Employer. (2) If Out of Work, give same particulars for last employer. (3) If employing paid persons, write "Employer." (4) If working on own account, write "Own account." For Domestic Servants and private personal service, write "Private."</_longname>
			</column>
			<column>
				<_attribute>Duration of Marriage (Years)</_attribute>
				<size>4</size>
				<_longname>Married Women: Completed years the present marriage has lasted.</_longname>
			</column>
			<column>
				<_attribute>Duration of Marriage (Months)</_attribute>
				<size>4</size>
				<_longname>Married Women: Completed months the present marriage has lasted.</_longname>
			</column>
			<column>
				<_attribute>Children Born Alive</_attribute>
				<size>5</size>
				<_longname>Married Women: Number of children born alive to the present marriage. If none, write "None."</_longname>
			</column>
			<column>
				<_attribute>Dependants Under 18</_attribute>
				<size>7</size>
				<_longname>Married Men, Widowers and Widows: Number of living sons, daughters, step-sons and step-daughters under 18 years of age, whether residing in this household or elsewhere. If none, write "None."</_longname>
			</column>
		</section>
