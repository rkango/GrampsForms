		</heading>
		<heading>
			<_attribute>Agricultural Holdings (Statute Acres)</_attribute>
			<_longname>Total area in statute acres of all agricultural holdings (if any) situated in the Irish Free State of which persons usually resident in this household are the rated occupiers.</_longname>
		</heading>
		<section role='Primary' type='multi'>
			<column>
				<_attribute>Name</_attribute>
				<size>18</size>
				<_longname>Name and Surname</_longname>
